{
  "name": "anagrama-oculto-devflow",
  "private": true,
  "version": "1.0.0",
  "description": "Atalhos de desenvolvimento para o app Flutter Anagrama Oculto.",
  "scripts": {
    "doctor": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 doctor -v",
    "pub:get": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 pub get",
    "android:devices": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 devices",
    "android:emulators": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 emulators",
    "android:start": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 emulators --launch",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 run",
    "dev:ads": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 run --dart-define=ADS_ENABLED=true --dart-define=ADMOB_ANDROID_BANNER_ID=%ADMOB_ANDROID_BANNER_ID% --dart-define=ADMOB_ANDROID_INTERSTITIAL_ID=%ADMOB_ANDROID_INTERSTITIAL_ID%",
    "analyze": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 analyze --no-pub",
    "test:flutter": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 test --no-pub",
    "build:apk": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 build apk --release",
    "build:apk:ranking": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 build apk --release --dart-define=RANKING_API_URL=%RANKING_API_URL%",
    "build:apk:ranking:prod": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 build apk --release --dart-define=RANKING_API_URL=https://anagrama-oculto-ranking.maycowcarrara.workers.dev",
    "build:aab": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 build appbundle --release",
    "build:aab:ranking": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 build appbundle --release --dart-define=RANKING_API_URL=%RANKING_API_URL%",
    "build:aab:ranking:prod": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 build appbundle --release --dart-define=RANKING_API_URL=https://anagrama-oculto-ranking.maycowcarrara.workers.dev",
    "build:aab:ads": "powershell -ExecutionPolicy Bypass -File scripts/run-flutter.ps1 build appbundle --release --dart-define=ADS_ENABLED=true --dart-define=ADMOB_ANDROID_BANNER_ID=%ADMOB_ANDROID_BANNER_ID% --dart-define=ADMOB_ANDROID_INTERSTITIAL_ID=%ADMOB_ANDROID_INTERSTITIAL_ID%",
    "audio:compress": "powershell -ExecutionPolicy Bypass -File scripts/compress-audio.ps1",
    "admin:logs": "powershell -ExecutionPolicy Bypass -File scripts/admin-logs.ps1",
    "admin:logs:simulate": "powershell -ExecutionPolicy Bypass -File scripts/simulate-error-log.ps1"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
